# Resend (contact form, calculator lead & estimate emails)
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxx
# Optional: "From" address. Must use a domain you verify at https://resend.com/domains (not @gmail.com).
# If unset or Gmail, emails send from "Fennor Developments <onboarding@resend.dev>".
# Example after verifying fennordevelopments.ie: RESEND_FROM="Fennor Developments <hello@fennordevelopments.ie>"
# RESEND_FROM="Fennor Developments <hello@yourdomain.ie>"
